# Next.js site
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=

# 公开部署必须使用 Supabase；本地开发可设 local
AUTH_STORAGE_MODE=supabase

# Python RAG Agent (right-corner assistant backend)
# Start with: npm run agent:dev
AGENT_URL=http://127.0.0.1:8001

# Personal asset tracker FastAPI backend (rewritten from /api/dashboard etc.)
# Start with: npm run asset-tracker:api
ASSET_TRACKER_API_URL=http://127.0.0.1:8000

# Auth (session signing). MUST be the same for Next + Asset API.
# Generate: openssl rand -hex 32
AUTH_SECRET=

# 助手额度：游客每日免费次数 / 登录用户签到奖励次数
GUEST_CHAT_LIMIT=3
CHAT_CHECKIN_REWARD=10

# 生产 CORS：逗号分隔完整源，例如 https://example.com
# 开发可留空（后端默认 *）
ALLOWED_ORIGINS=

# 是否要求注册用户验证邮箱；false 表示注册后直接登录
EMAIL_VERIFICATION_REQUIRED=false

# 邮箱验证（仅当 EMAIL_VERIFICATION_REQUIRED=true 时需要）
# 推荐 Resend：https://resend.com
RESEND_API_KEY=
EMAIL_FROM=美股扫盲 <onboarding@resend.dev>
EMAIL_SITE_NAME=美股扫盲导航

# 隐私政策和用户支持联系方式（公开上线前必填）
NEXT_PUBLIC_CONTACT_EMAIL=

# 数据看板管理员邮箱，多个邮箱用英文逗号分隔
# 登录后访问 /admin/metrics；生产环境未配置时任何人都无法进入
ADMIN_EMAILS=
