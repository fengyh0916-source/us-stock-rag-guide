# Supabase Postgres 连接串（优先；不填则用本地 SQLite）
# Dashboard → Project Settings → Database → Connection string (URI)
# 推荐 Transaction pooler 端口 6543
DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# 公网部署必填；与 Next.js 站点完全一致，至少 32 字符
AUTH_SECRET=
ALLOWED_ORIGINS=https://your-domain.example
ENVIRONMENT=production

# 盈透 IB Gateway / TWS（同步持仓用）
# Gateway 实盘 4001 / 模拟 4002；TWS 实盘 7496 / 模拟 7497
IB_HOST=127.0.0.1
IB_PORT=4001
IB_CLIENT_ID=7
